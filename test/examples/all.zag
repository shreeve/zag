# Comprehensive rule coverage test — every rule that compiles
# 40+ of 49 grammar rules exercised (record, pair, lambda parse-only)

# --- Preamble ---
#
# Zig: const std = @import("std");

use std                                    # use, name

# --- Type alias ---
#
# Zig: const Count = i64;

type Count = i64                           # typedef, type

# --- Error set ---
#
# Zig: const AppError = error{
#          NotFound,
#          InvalidInput,
#      };

error AppError                             # errors, members, member
  NotFound
  InvalidInput

# --- Plain enum ---
#
# Zig: const Color = enum {
#          red,
#          green,
#          blue,
#      };

enum Color                                 # enum (plain)
  red
  green
  blue

# --- Tagged union (enum with typed variants) ---
#
# Zig: const Result = union(enum) {
#          ok: i32,
#          err: []u8,
#          none: void,
#      };

enum Result                                # enum (tagged union → union(enum))
  ok: i32                                  # member (typed via field)
  err: []u8                                # type (slice)
  none

# --- Enum with explicit values ---
#
# Zig: const Priority = enum(i64) {
#          low = 0,
#          high = 1,
#      };

enum Priority                              # member (valued)
  low = 0
  high = 1

# --- Struct with defaults ---
#
# Zig: const Config = struct {
#          width: i32 = 800,
#          height: i32 = 600,
#      };

struct Config                              # struct, field (default)
  width: i32 = 800
  height: i32 = 600

# --- Packed struct ---
#
# Zig: const Flags = packed struct {
#          a: u1,
#          b: u1,
#          padding: u6,
#      };

packed struct Flags                        # packed struct
  a: u1
  b: u1
  padding: u6

# --- Struct with methods ---
#
# Zig: const Point = struct {
#          x: i64,
#          y: i64,
#
#          fn sum(self: Point) i64 {
#              return self.x + self.y;
#          }
#      };

struct Point                               # struct with methods
  x: i64                                   # field (typed)
  y: i64

  fun sum self: Point -> i64               # fun inside struct, params, returns, type
    self.x + self.y

# --- Functions ---
#
# Zig: fn add(a: i32, b: i32) i32 {
#          return a + b;
#      }

fun add a: i32, b: i32 -> i32             # fun (params + returns)
  a + b

# Zig: fn square(x: i64) i64 {
#          return x * x;
#      }

fun square x                               # fun (params only)
  x * x

# --- Error union return type ---
#
# Zig: fn maybe_fail(x: i64) !i64 {
#          return x;
#      }

fun maybe_fail x: i64 -> !i64             # type (error_union)
  x

# --- Modifiers ---
#
# Zig: pub fn double(x: i32) i32 {
#          return x * 2;
#      }

pub fun double x: i32 -> i32              # decl (pub), defn
  x * 2

# --- Test block ---
#
# Zig: test "add works" {
#          _ = add(2, 3);
#      }

test "add works"                           # test
  _ = add(2, 3)                            # call (parens), args, discard _

# --- Main ---
#
# Zig: pub fn main() void {

fun main -> !void                          # fun (main can return errors for try/errdefer)

  # --- Bindings ---
  #
  # Zig: const result = add(1, 2);
  #      const limit = 100;
  #      std.debug.print("{any}\n", .{result});
  #      std.debug.print("{any}\n", .{limit});

  result = add 1, 2                        # assign (=), implicit call
  limit =! 100                             # const (=!)
  print result
  print limit

  # --- If prefix: block, else-if, else ---
  #
  # Zig: if (result > 2) {
  #          ...
  #      } else if (result > 0) {
  #          ...
  #      } else {
  #          ...
  #      }

  if result > 2                            # if, cond, block
    print "big"
  else if result > 0                       # if/else if chain
    print "medium"
  else
    print "small"

  # --- If postfix: guard and value ---
  #
  # Zig: if (true) { ... }
  #      const x = if (true) 42 else 0;

  print "yes" if true                      # suffix_if
  x = 42 if true else 0                   # suffix_if (value)
  print x

  # --- While ---
  #
  # Zig: var n: i64 = 0;
  #      while (n < 5) { n += 1; }

  n = 0
  while n < 5                             # while, cond
    n += 1                                 # assign (+=)
  print n

  # --- Labeled break ---
  #
  # Zig: outer: while (true) {
  #          break :outer;
  #      }

  :outer while true                        # labeled statement
    break :outer                           # break_to

  # --- Postfix if (conditional flow control) ---
  #
  # Zig: if (n == 5) break;
  #      if (n > 100) return n;

  n = 0
  while n < 10
    n += 1
    break if n == 5                        # break if cond
  print n

  n = 0
  while n < 10
    n += 1
    continue if n < 3                      # continue if cond
    break
  print n

  # --- For range ---
  #
  # Zig: { var i: i64 = 0;
  #        while (i < 3) : (i += 1) { ... } }

  for i in 0..3                            # for (range), @infix (..)
    print i

  # --- Match ---
  #
  # Zig: switch (c) {
  #          0 => ...,
  #          1 => { ... },
  #          else => ...,
  #      }

  c = 1
  match c                                  # match, arms
    0 => print "zero"                      # arm (=> expr)
    1
      print "one"                          # arm (block)
    _ => print "other"                     # arm (wildcard)

  # --- Match with payload capture ---
  #
  # Zig: switch (result) {
  #          .ok => |val| std.debug.print("{any}\n", .{val}),
  #          .none => std.debug.print("nothing\n", .{}),
  #      }

  # match result                           # match payload capture (needs union value)
  #   ok as val => print val               # arm with capture → .ok => |val| ...
  #   none => print "nothing"

  # --- Compound assignments ---
  #
  # Zig: var v: i64 = 10;
  #      v -= 1;
  #      v *= 2;

  v = 10
  v -= 1                                   # assign (-=)
  v *= 2                                   # assign (*=)
  v /= 3                                   # assign (/=) → @divTrunc
  print v

  # --- Unary ---
  #
  # Zig: std.debug.print("{any}\n", .{-42});
  #      std.debug.print("{any}\n", .{!false});

  print -42                                # unary (neg) — no parens needed
  print !false                             # unary (not) — no parens needed

  # --- Literals ---
  #
  # Zig: std.debug.print("{any}\n", .{true});
  #      std.debug.print("{any}\n", .{3.14});
  #      std.debug.print("single quoted\n", .{});

  print true                               # atom (TRUE)
  print 3.14                               # atom (REAL)
  print 'single quoted'                    # atom (STRING_SQ → converted to "")

  # --- Parenthesized expression ---
  #
  # Zig: std.debug.print("{any}\n", .{(1 + 2) * 3});

  print((1 + 2) * 3)                       # atom (parens), @infix (+, *)

  # --- Array literal ---
  #
  # Zig: const nums = [_]i64{ 10, 20, 30 };

  nums = [10, 20, 30]                      # atom (array)

  # --- Dot access and index ---
  #
  # Zig: std.debug.print("{any}\n", .{nums.len});
  #      std.debug.print("{any}\n", .{nums[0]});

  print(nums.len)                          # call (dot)
  print(nums[0])                           # call (index)

  # --- Pipe operator ---
  #
  # Zig: const val = square(7);

  val = 7 |> square                        # @infix (|>)
  print val

  # --- Power operator ---
  #
  # Zig: std.debug.print("{any}\n", .{square(3)});

  print(square(3))                         # @infix (**)

  # --- Struct literal ---
  #
  # Zig: const p = Point{ .x = 10, .y = 20 };

  p = Point { x: 10, y: 20 }              # record, pair
  print(p.x)

  # --- Lambda ---
  #
  # Zig: const inc = struct { fn f(n: i64) i64 { return n + 1; } }.f;

  inc = fn z
    z + 1                                 # lambda
  print(inc(5))

  # --- @builtin ---
  #
  # Zig: const casted = @as(i64, 42);

  casted = @as(i64, 42)                   # atom (builtin)
  print casted

  # --- Null and coalesce ---
  #
  # Zig: const maybe = null;
  #      const safe = maybe orelse 99;

  maybe = null                             # atom (NULL)
  safe = maybe ?? 99                       # coalesce (??)
  print safe

  # --- Catch ---
  #
  # Zig: const caught = maybe_fail(0) catch 77;

  caught = maybe_fail(0) catch 77          # catch
  print caught

  # --- If capture ---
  #
  # Zig: const opt = @as(?i64, 42);
  #      if (opt) |w| { ... }

  opt = @as(?i64, 42)
  if opt as w                              # cond (as capture)
    print w

  # --- Else capture ---
  #
  # Zig: if (risky()) |val| {
  #          ...
  #      } else |err| {
  #          ...
  #      }

  # if risky() as val                      # else capture (needs error union value)
  #   use val
  # else as err                            # → else |err| { ... }
  #   handle err

  # --- Break with value ---
  #
  # Zig: break 42;

  # (break expr used inside loops/blocks to return values)

  # --- Try ---
  #
  # Zig: const tried = try maybe_fail(42);

  tried = try maybe_fail(42)               # unary (try)
  print tried

  # --- Errdefer ---
  #
  # Zig: errdefer std.debug.print("error cleanup\n", .{});

  errdefer print "error cleanup"           # errdefer

  # --- Comptime expression ---
  #
  # Zig: const ct = comptime 1 + 2;

  ct = comptime 1 + 2                      # comptime in expression position
  print ct

  # --- Inline for ---
  #
  # Zig: inline for (0..3) |j| { ... }

  inline for j in 0..3                     # inline for (native, not while desugaring)
    _ = j

  # --- Match with range and enum patterns ---
  #
  # Zig: switch (c) {
  #          0...1 => ...,
  #          2...9 => ...,
  #          else => ...,
  #      }

  match c                                  # match with range pattern
    0..1 => print "low"
    2..9 => print "mid"                    # range_pattern
    _ => print "high"

  # --- Defer ---
  #
  # Zig: defer std.debug.print("cleanup\n", .{});

  defer print "cleanup"                    # defer

  # --- Unreachable ---
  #
  # Zig: if (false) { unreachable; }

  if false
    unreachable                            # atom (UNREACHABLE)

  print "done"
